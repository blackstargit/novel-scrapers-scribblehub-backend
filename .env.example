# Gmail credentials — generate an App Password at:
# https://myaccount.google.com/security → 2-Step Verification → App Passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Security: restrict which hostnames/origins can reach the API
# Comma-separated. Use * to allow all (local dev only).
ALLOWED_HOSTS=YOUR-DOMAIN.duckdns.org
ALLOWED_ORIGINS=https://YOUR-DOMAIN.duckdns.org

# FlareSolverr URL — docker-compose sets this automatically via env.
# Only needed when running the backend locally without compose.
FLARESOLVERR_URL=http://localhost:8191
